{
  "expo": {
    "name": "Vaultis",
    "slug": "bloom-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "vaultis",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Vaultis uses Face ID to protect your wallet"
        }
      ]
    ],
    "android": {
      "package": "com.vaultis.wallet",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vaultis.wallet"
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb01f8be-a0a0-4e63-83d2-09b117497683"
      }
    },
    "owner": "rahulpatle-sol"
  }
}
