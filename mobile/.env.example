# ============================================
# BLOOM — Environment Variables
# Copy this file, rename to .env
# NEVER commit .env to git
# ============================================

# Network: devnet | mainnet-beta
EXPO_PUBLIC_NETWORK=devnet

# Your deployed program ID (update after: solana program deploy)
EXPO_PUBLIC_PROGRAM_ID_DEVNET=YOUR_PROGRAM_ID_HERE
EXPO_PUBLIC_PROGRAM_ID_MAINNET=

# Optional: Helius RPC for mainnet (faster)
# Get free key at https://helius.dev
EXPO_PUBLIC_HELIUS_KEY=
