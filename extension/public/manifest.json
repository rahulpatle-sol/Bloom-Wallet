{
  "manifest_version": 3,
  "name": "Bloom Wallet",
  "version": "1.0.0",
  "description": "Biometric Solana wallet with Digital Will — no seed phrase",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}